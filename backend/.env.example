NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/academy
PUBLIC_APP_URL=http://localhost:5173
QUESTIONNAIRE_TOKEN_EXPIRES_DAYS=30
CORS_ORIGINS=http://localhost:5173
TRUST_PROXY=false
JSON_BODY_LIMIT=1mb
DISABLE_RATE_LIMITS=false

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=3000

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=100

PUBLIC_QUESTIONNAIRE_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_QUESTIONNAIRE_RATE_LIMIT_MAX=300

EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@example.com
SMTP_PASS=change_me
EMAIL_FROM_NAME=Лятна академия
EMAIL_FROM_ADDRESS=no-reply@example.com
EMAIL_REPLY_TO=support@example.com
EMAIL_TEST_RECIPIENT=test@example.com

JWT_ACCESS_SECRET=change_me
JWT_ACCESS_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10

SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin